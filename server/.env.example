# ============================================================
# M3M Brabus backend — environment variables
# Copy to `.env` and fill in. NEVER commit the real .env.
# ============================================================

# Node environment: development | production
NODE_ENV=development

# Port the API listens on.
PORT=4000

# Neon PostgreSQL connection string (Prisma reads this).
# Neon → your project → Connection Details → "Prisma" tab. Keep ?sslmode=require.
# Use the POOLED connection string for the app; the direct one for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# The existing Google Apps Script web-app URL (the /exec URL you already use).
GOOGLE_SCRIPT_URL="https://script.google.com/macros/s/AKfycby.../exec"

# Which store is primary: "prisma" (Neon) now, "crm" later. See README.
LEAD_STORE=prisma

# Comma-separated browser origins allowed to call the API. Use your live domain
# in production. "*" allows any (development only — do not use in production).
CORS_ORIGIN=http://localhost:5173,https://m3m-brabus.vercel.app

# Rate limit: max POST /api/leads per IP per window.
RATE_LIMIT=30
RATE_LIMIT_WINDOW_MS=900000

# Max accepted request body size and outbound Apps Script timeout.
JSON_BODY_LIMIT=16kb
GOOGLE_TIMEOUT_MS=10000

# Log verbosity: error | warn | info | debug
LOG_LEVEL=info
